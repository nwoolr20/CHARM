#!/bin/bash

# Launch_CHARM - Easy launcher for the CHARM Security Suite
# 
# This script provides convenient access to the CHARM Security Suite CLI
# with automatic build detection and helpful usage information.

set -e

# Script directory and project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

# Color definitions for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print colored message
print_color() {
    local color=$1
    local message=$2
    echo -e "${color}${message}${NC}"
}

# Print banner
print_banner() {
    echo ""
    print_color $BLUE "╔═══════════════════════════════════════════════╗"
    print_color $BLUE "║           CHARM Security Suite Launcher       ║"
    print_color $BLUE "║     Enterprise-Grade Cryptographic Platform   ║"
    print_color $BLUE "╚═══════════════════════════════════════════════╝"
    echo ""
}

# Print usage information
print_usage() {
    print_banner
    echo "Usage: $0 [OPTIONS] [CLI_ARGUMENTS...]"
    echo ""
    echo "Launcher Options:"
    echo "  -h, --help          Show this help message"
    echo "  -b, --build         Force rebuild before launching"
    echo "  -v, --version       Show CHARM version information"
    echo "  -s, --status        Quick status check"
    echo ""
    echo "Quick Actions:"
    echo "  --build-only        Build the security suite without launching"
    echo "  --test-pbkdf2       Test PBKDF2 functionality"
    echo "  --demo              Run demonstration of key features"
    echo ""
    echo "Examples:"
    echo "  $0                                    # Launch with help"
    echo "  $0 --status                          # Quick status check"
    echo "  $0 --pbkdf2-config                   # Show PBKDF2 configuration"
    echo "  $0 --pbkdf2-derive \"password:100000\"  # Derive key from password"
    echo "  $0 --health --capabilities           # Health check and capabilities"
    echo ""
    echo "All other arguments are passed directly to the CHARM Security Suite CLI."
    echo "For full CLI help: $0 --help"
}

# Check if build exists and is up to date
check_build() {
    local cli_binary="$PROJECT_ROOT/build/charm_security_suite"
    
    if [[ ! -f "$cli_binary" ]]; then
        print_color $YELLOW "CLI binary not found. Building CHARM Security Suite..."
        return 1
    fi
    
    # Check if any source files are newer than the binary
    local newest_source
    newest_source=$(find "$PROJECT_ROOT/src" "$PROJECT_ROOT/PBKDF2" -name "*.c" -o -name "*.h" 2>/dev/null | xargs ls -t 2>/dev/null | head -n1)
    
    if [[ -n "$newest_source" && "$newest_source" -nt "$cli_binary" ]]; then
        print_color $YELLOW "Source files are newer than binary. Rebuilding..."
        return 1
    fi
    
    return 0
}

# Build the security suite
build_suite() {
    print_color $BLUE "Building CHARM Security Suite with PBKDF2..."
    
    cd "$PROJECT_ROOT"
    
    # Ensure build directory exists
    mkdir -p build
    
    # Build the security suite
    if make security_suite; then
        print_color $GREEN "✓ Build completed successfully"
        return 0
    else
        print_color $RED "✗ Build failed"
        return 1
    fi
}

# Test PBKDF2 functionality
test_pbkdf2() {
    print_color $BLUE "Testing PBKDF2 functionality..."
    local cli_binary="$PROJECT_ROOT/build/charm_security_suite"
    
    echo ""
    print_color $YELLOW "1. PBKDF2 Configuration:"
    "$cli_binary" --pbkdf2-config
    
    echo ""
    print_color $YELLOW "2. PBKDF2 Benchmark:"
    "$cli_binary" --pbkdf2-benchmark
    
    echo ""
    print_color $YELLOW "3. Salt Generation (16 bytes):"
    "$cli_binary" --pbkdf2-salt 16
    
    echo ""
    print_color $YELLOW "4. Key Derivation Test:"
    "$cli_binary" --pbkdf2-derive "testpassword:10000"
    
    echo ""
    print_color $GREEN "✓ PBKDF2 tests completed"
}

# Run demonstration
run_demo() {
    print_color $BLUE "CHARM Security Suite Demonstration"
    local cli_binary="$PROJECT_ROOT/build/charm_security_suite"
    
    echo ""
    print_color $YELLOW "=== Security Suite Status ==="
    "$cli_binary" --status --capabilities
    
    echo ""
    print_color $YELLOW "=== Health Check ==="
    "$cli_binary" --health
    
    echo ""
    print_color $YELLOW "=== PBKDF2 Demonstration ==="
    test_pbkdf2
    
    echo ""
    print_color $YELLOW "=== CHARM Algorithm Tests ==="
    "$cli_binary" --charm-core --charm-b
    
    echo ""
    print_color $GREEN "✓ Demonstration completed"
}

# Show version information
show_version() {
    print_banner
    local cli_binary="$PROJECT_ROOT/build/charm_security_suite"
    
    if [[ -f "$cli_binary" ]]; then
        "$cli_binary" --version
    else
        echo "CHARM Security Suite (not built)"
    fi
    
    echo ""
    echo "Project: CHARM Security Suite"
    echo "Repository: https://github.com/nwoolr20/CHARM"
    echo "Features: Entropy-native cryptography, PBKDF2, AEAD, Security monitoring"
}

# Main function
main() {
    local force_build=false
    local build_only=false
    local show_help=false
    local show_version_info=false
    local status_check=false
    local test_pbkdf2_flag=false
    local demo_flag=false
    
    # Parse launcher-specific arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_help=true
                shift
                ;;
            -b|--build)
                force_build=true
                shift
                ;;
            -v|--version)
                show_version_info=true
                shift
                ;;
            -s|--status)
                status_check=true
                shift
                ;;
            --build-only)
                build_only=true
                shift
                ;;
            --test-pbkdf2)
                test_pbkdf2_flag=true
                shift
                ;;
            --demo)
                demo_flag=true
                shift
                ;;
            *)
                # Pass remaining arguments to CLI
                break
                ;;
        esac
    done
    
    # Handle launcher-specific actions
    if [[ "$show_help" == true ]]; then
        print_usage
        return 0
    fi
    
    if [[ "$show_version_info" == true ]]; then
        show_version
        return 0
    fi
    
    # Check/build the suite
    if [[ "$force_build" == true ]] || ! check_build; then
        if ! build_suite; then
            print_color $RED "Failed to build CHARM Security Suite"
            return 1
        fi
    fi
    
    if [[ "$build_only" == true ]]; then
        print_color $GREEN "Build completed. Use '$0' to launch the CLI."
        return 0
    fi
    
    local cli_binary="$PROJECT_ROOT/build/charm_security_suite"
    
    # Handle special actions
    if [[ "$test_pbkdf2_flag" == true ]]; then
        test_pbkdf2
        return 0
    fi
    
    if [[ "$demo_flag" == true ]]; then
        run_demo
        return 0
    fi
    
    if [[ "$status_check" == true ]]; then
        print_color $BLUE "CHARM Security Suite Status Check"
        "$cli_binary" --status --capabilities --health
        return 0
    fi
    
    # If no arguments, show help from CLI
    if [[ $# -eq 0 ]]; then
        print_banner
        print_color $YELLOW "Launching CHARM Security Suite CLI..."
        echo ""
        "$cli_binary" --help
        return 0
    fi
    
    # Launch CLI with provided arguments
    print_color $BLUE "Launching CHARM Security Suite..."
    exec "$cli_binary" "$@"
}

# Run main function with all arguments
main "$@"